{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.45.15.27210",
      "templateHash": "8595023156759533703"
    }
  },
  "parameters": {
    "healthModelName": {
      "type": "string",
      "metadata": {
        "description": "Name of the health model. This also becomes the root entity name."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources."
      }
    },
    "tagName": {
      "type": "string",
      "defaultValue": "workload",
      "metadata": {
        "description": "Tag name used to identify resources for discovery."
      }
    },
    "tagValue": {
      "type": "string",
      "defaultValue": "my-web-app",
      "metadata": {
        "description": "Tag value to match."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.CloudHealth/healthmodels",
      "apiVersion": "2026-05-01-preview",
      "name": "[parameters('healthModelName')]",
      "location": "[parameters('location')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {}
    },
    {
      "type": "Microsoft.CloudHealth/healthmodels/authenticationsettings",
      "apiVersion": "2026-05-01-preview",
      "name": "[format('{0}/{1}', parameters('healthModelName'), 'default-auth')]",
      "properties": {
        "displayName": "Default Authentication",
        "authenticationKind": "ManagedIdentity",
        "managedIdentityName": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CloudHealth/healthmodels', parameters('healthModelName'))]"
      ]
    },
    {
      "type": "Microsoft.CloudHealth/healthmodels/entities",
      "apiVersion": "2026-05-01-preview",
      "name": "[format('{0}/{1}', parameters('healthModelName'), 'compute')]",
      "properties": {
        "displayName": "Compute"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CloudHealth/healthmodels', parameters('healthModelName'))]"
      ]
    },
    {
      "type": "Microsoft.CloudHealth/healthmodels/relationships",
      "apiVersion": "2026-05-01-preview",
      "name": "[format('{0}/{1}', parameters('healthModelName'), format('{0}-compute', parameters('healthModelName')))]",
      "properties": {
        "parentEntityName": "[parameters('healthModelName')]",
        "childEntityName": "compute"
      },
      "dependsOn": [
        "[resourceId('Microsoft.CloudHealth/healthmodels/entities', parameters('healthModelName'), 'compute')]",
        "[resourceId('Microsoft.CloudHealth/healthmodels', parameters('healthModelName'))]"
      ]
    },
    {
      "type": "Microsoft.CloudHealth/healthmodels/discoveryrules",
      "apiVersion": "2026-05-01-preview",
      "name": "[format('{0}/{1}', parameters('healthModelName'), 'compute')]",
      "properties": {
        "displayName": "Discover VMs",
        "authenticationSetting": "default-auth",
        "discoverRelationships": "Enabled",
        "addRecommendedSignals": "Enabled",
        "addResourceHealthSignal": "Enabled",
        "specification": {
          "kind": "ResourceGraphQuery",
          "resourceGraphQuery": "[format('resources | where type =~ ''microsoft.compute/virtualmachines'' and tags[''{0}''] =~ ''{1}''', parameters('tagName'), parameters('tagValue'))]"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.CloudHealth/healthmodels/authenticationsettings', parameters('healthModelName'), 'default-auth')]",
        "[resourceId('Microsoft.CloudHealth/healthmodels/entities', parameters('healthModelName'), 'compute')]",
        "[resourceId('Microsoft.CloudHealth/healthmodels', parameters('healthModelName'))]"
      ]
    }
  ],
  "outputs": {
    "healthModelName": {
      "type": "string",
      "value": "[parameters('healthModelName')]"
    },
    "healthModelId": {
      "type": "string",
      "value": "[resourceId('Microsoft.CloudHealth/healthmodels', parameters('healthModelName'))]"
    },
    "location": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.CloudHealth/healthmodels', parameters('healthModelName')), '2026-05-01-preview', 'full').location]"
    }
  }
