{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "imagePublisher": {
      "type": "string",
      "metadata": {
        "description": "Publisher of the marketplace image (e.g. Canonical, Redhat, Suse)"
      }
    },
    "imageOffer": {
      "type": "string",
      "metadata": {
        "description": "Offer of the marketplace image (e.g. 0001-com-ubuntu-server-jammy, rhel, sles-15-sp5)"
      }
    },
    "imageSku": {
      "type": "string",
      "metadata": {
        "description": "SKU of the marketplace image (e.g. 22_04-lts-gen2, 90-gen2, gen2)"
      }
    },
    "imageVersion": {
      "type": "string",
      "defaultValue": "latest",
      "metadata": {
        "description": "Version of the marketplace image (e.g. latest)"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Resource group location"
       }
     },
    "testregion": {
      "type": "string",
      "defaultValue": "centralus",
      "allowedValues": [
        "australiacentral",
        "westus",
        "eastus",
        "norwayeast",
        "japanwest",
        "switzerlandnorth",
        "eastasia",
        "israelcentral",
        "brazilsoutheast",
        "australiasoutheast",
        "uaenorth",
        "germanynorth",
        "spaincentral",
        "southafricanorth",
        "centraluseuap",
        "koreacentral",
        "italynorth",
        "uaecentral",
        "francecentral",
        "norwaywest",
        "westus3",
        "southafricawest",
        "koreasouth",
        "francesouth",
        "westus2",
        "australiaeast",
        "polandcentral",
        "centralus",
        "southeastasia",
        "southcentralus",
        "westcentralus",
        "japaneast",
        "westeurope",
        "canadacentral",
        "centralindia",
        "australiacentral2",
        "eastus2euap",
        "swedencentral",
        "germanywestcentral",
        "northeurope",
        "brazilsouth",
        "newzealandnorth",
        "northcentralus",
        "canadaeast",
        "eastus2",
        "swedensouth",
        "southindia",
        "uksouth",
        "switzerlandwest",
        "malaysiawest",
        "chilecentral",
        "jioindiawest",
        "ukwest",
        "taiwannorth",
        "israelnorthwest",
        "indonesiacentral",
        "malaysiasouth",
        "jioindiacentral",
        "mexicocentral",
        "taiwannorthwest",
        "austriaeast"
      ],
      "metadata": {
        "description": "Azure region for all resources"
      }
    }
  },
  "variables": {
    "osType": "Linux",
    "suffix": "[uniqueString(resourceGroup().id, parameters('imagePublisher'), parameters('imageOffer'), parameters('imageSku'), parameters('testregion'))]",
    "cleanPublisher": "[replace(replace(replace(toLower(parameters('imagePublisher')), '-', ''), '_', ''), '.', '')]",
    "cleanOffer": "[replace(replace(replace(toLower(parameters('imageOffer')), '-', ''), '_', ''), '.', '')]",
    "cleanSku": "[replace(replace(replace(toLower(parameters('imageSku')), '-', ''), '_', ''), '.', '')]",
    "diskName": "[concat('disk-', variables('cleanSku'), '-', variables('suffix'))]",
    "managedImageName": "[concat('mi-', variables('cleanSku'), '-', variables('suffix'))]",
    "galleryName": "[concat('gal_', variables('cleanPublisher'), '_', variables('cleanOffer'), '_', variables('suffix'))]",
    "imageDefinitionName": "[concat(toLower(parameters('imagePublisher')), '-', toLower(parameters('imageOffer')), '-', toLower(parameters('imageSku')))]",
    "imageVersionName": "1.0.0",
    "marketplaceImageId": "[subscriptionResourceId('Microsoft.Compute/Locations/Publishers/ArtifactTypes/Offers/Skus/Versions', parameters('testregion'), parameters('imagePublisher'), 'VMImage', parameters('imageOffer'), parameters('imageSku'), parameters('imageVersion'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Compute/disks",
      "apiVersion": "2025-01-02",
      "name": "[variables('diskName')]",
      "location": "[parameters('testregion')]",
      "sku": {
        "name": "Premium_LRS"
      },
      "properties": {
        "hyperVGeneration": "V2",
        "osType": "[variables('osType')]",
        "creationData": {
          "createOption": "FromImage",
          "imageReference": {
            "id": "[variables('marketplaceImageId')]"
          }
        }
      }
    },
    {
      "type": "Microsoft.Compute/images",
      "apiVersion": "2025-11-01",
      "name": "[variables('managedImageName')]",
      "location": "[parameters('testregion')]",
      "dependsOn": [
        "[resourceId('Microsoft.Compute/disks', variables('diskName'))]"
      ],
      "properties": {
        "hyperVGeneration": "V2",
        "storageProfile": {
          "osDisk": {
            "osType": "[variables('osType')]",
            "osState": "Generalized",
            "managedDisk": {
              "id": "[resourceId('Microsoft.Compute/disks', variables('diskName'))]"
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.Compute/galleries",
      "apiVersion": "2025-03-03",
      "name": "[variables('galleryName')]",
      "location": "[parameters('testregion')]",
      "properties": {
        "identifier": {}
      }
    },
    {
      "type": "Microsoft.Compute/galleries/images",
      "apiVersion": "2025-03-03",
      "name": "[concat(variables('galleryName'), '/', variables('imageDefinitionName'))]",
      "location": "[parameters('testregion')]",
      "dependsOn": [
        "[resourceId('Microsoft.Compute/galleries', variables('galleryName'))]"
      ],
      "properties": {
        "hyperVGeneration": "V2",
        "architecture": "x64",
        "osType": "[variables('osType')]",
        "osState": "Generalized",
        "identifier": {
          "publisher": "[parameters('imagePublisher')]",
          "offer": "[parameters('imageOffer')]",
          "sku": "[parameters('imageSku')]"
        },
        "features": [
          {
            "name": "SecurityType",
            "value": "TrustedLaunchAndConfidentialVmSupported"
          }
        ],
        "recommended": {
          "vCPUs": {
            "min": 1,
            "max": 16
          },
          "memory": {
            "min": 1,
            "max": 32
          }
        }
      }
    },
    {
      "type": "Microsoft.Compute/galleries/images/versions",
      "apiVersion": "2025-03-03",
      "name": "[concat(variables('galleryName'), '/', variables('imageDefinitionName'), '/', variables('imageVersionName'))]",
      "location": "[parameters('testregion')]",
      "dependsOn": [
        "[resourceId('Microsoft.Compute/galleries/images', variables('galleryName'), variables('imageDefinitionName'))]",
        "[resourceId('Microsoft.Compute/galleries', variables('galleryName'))]",
        "[resourceId('Microsoft.Compute/images', variables('managedImageName'))]"
      ],
      "properties": {
        "publishingProfile": {
          "replicationMode": "Shallow",
          "targetRegions": [
            {
              "name": "[parameters('testregion')]",
              "regionalReplicaCount": 1,
              "storageAccountType": "Premium_LRS"
            }
          ]
        },
        "storageProfile": {
          "source": {
            "id": "[resourceId('Microsoft.Compute/images', variables('managedImageName'))]"
          }
        },
        "securityProfile": {
          "uefiSettings": {
            "signatureTemplateNames": [
              "NoSignatureTemplate"
            ],
            "additionalSignatures": {
              "PK": {
                "type": "x509",
                "value": [
                  ""
                ]
              },
              "KEK": [
                {
                  "type": "x509",
                  "value": [
                    ""
                  ]
                }
              ],
              "db": [
                {
                  "type": "x509",
                  "value": [
                    ""
                  ]
                }
              ]
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "galleryImageVersionId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Compute/galleries/images/versions', variables('galleryName'), variables('imageDefinitionName'), variables('imageVersionName'))]"
    },
    "testregion": {
      "type": "string",
      "value": "[parameters('testregion')]"
    }
  }
}
