{
    "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
    "handler": "Microsoft.Azure.CreateUIDef",
    "version": "0.1.2-preview",
    "parameters": {
        "config": {
            "basics": {
                "location": {
                    "allowedValues": [
                        "australiacentral",
                        "westus",
                        "eastus",
                        "norwayeast",
                        "japanwest",
                        "switzerlandnorth",
                        "eastasia",
                        "israelcentral",
                        "brazilsoutheast",
                        "australiasoutheast",
                        "uaenorth",
                        "germanynorth",
                        "spaincentral",
                        "southafricanorth",
                        "centraluseuap",
                        "koreacentral",
                        "italynorth",
                        "uaecentral",
                        "francecentral",
                        "norwaywest",
                        "westus3",
                        "southafricawest",
                        "koreasouth",
                        "francesouth",
                        "westus2",
                        "australiaeast",
                        "polandcentral",
                        "centralus",
                        "southeastasia",
                        "southcentralus",
                        "westcentralus",
                        "japaneast",
                        "westeurope",
                        "canadacentral",
                        "centralindia",
                        "australiacentral2",
                        "eastus2euap",
                        "swedencentral",
                        "germanywestcentral",
                        "northeurope",
                        "brazilsouth",
                        "newzealandnorth",
                        "northcentralus",
                        "canadaeast",
                        "eastus2",
                        "southcentralusstg",
                        "swedensouth",
                        "southindia",
                        "uksouth",
                        "switzerlandwest",
                        "malaysiawest",
                        "chilecentral",
                        "jioindiawest",
                        "ukwest",
                        "taiwannorth",
                        "israelnorthwest",
                        "indonesiacentral",
                        "malaysiasouth",
                        "jioindiacentral",
                        "mexicocentral",
                        "taiwannorthwest",
                        "austriaeast"
                    ]
                }
            }
        },
        "basics": [
            {
                "name": "imagePublisher",
                "type": "Microsoft.Common.TextBox",
                "label": "Image Publisher",
                "toolTip": "Publisher of the marketplace image (e.g. Canonical, Redhat, Suse)",
                "defaultValue": "",
                "constraints": {
                    "required": true,
                    "validationMessage": "Please enter a valid image publisher."
                }
            },
            {
                "name": "imageOffer",
                "type": "Microsoft.Common.TextBox",
                "label": "Image Offer",
                "toolTip": "Offer of the marketplace image (e.g. 0001-com-ubuntu-server-jammy, rhel, sles-15-sp5)",
                "defaultValue": "",
                "constraints": {
                    "required": true,
                    "validationMessage": "Please enter a valid image offer."
                }
            },
            {
                "name": "imageSku",
                "type": "Microsoft.Common.TextBox",
                "label": "Image SKU",
                "toolTip": "SKU of the marketplace image (e.g. 22_04-lts-gen2, 90-gen2, gen2)",
                "defaultValue": "",
                "constraints": {
                    "required": true,
                    "validationMessage": "Please enter a valid image SKU."
                }
            },
            {
                "name": "imageVersion",
                "type": "Microsoft.Common.TextBox",
                "label": "Image Version",
                "toolTip": "Version of the marketplace image (e.g. latest)",
                "defaultValue": "",
                "constraints": {
                    "required": true,
                    "validationMessage": "Please enter a valid image version."
                }
            }
        ],
        "steps": [],
        "outputs": {
            "location": "[location()]",
            "imagePublisher": "[basics('imagePublisher')]",
            "imageOffer": "[basics('imageOffer')]",
            "imageSku": "[basics('imageSku')]",
            "imageVersion": "[basics('imageVersion')]"
        }
    }
}
