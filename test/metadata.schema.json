{
  "properties": {
    "$schema": {
      "type": "string",
      "enum": [
        "https://aka.ms/azure-quickstart-templates-metadata-schema#"
      ],
      "description": "JSON schema reference"
    },
    "itemDisplayName": {
      "type": "string",
      "minLength": 10,
      "maxLength": 60
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1000
    },
    "summary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200
    },
    "githubUsername": {
      "type": "string",
      "pattern": "^[a-zA-Z\\d](?:[a-zA-Z\\d]|-(?=[a-zA-Z\\d])){0,38}$"
    },
    "docOwner": {
      "type": "string",
      "pattern": "^[a-zA-Z\\d](?:[a-zA-Z\\d]|-(?=[a-zA-Z\\d])){0,38}$"
    },
    "dateUpdated": {
      "type": "string",
      "pattern": "^(20[1-9][0-9])-(0[1-9]|1[012])-(0[1-9]|[12][0-9]|3[01])$"
    },
    "validationType": {
      "type": "string",
      "enum": [
        "Manual",
        "Automated"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "QuickStart",
        "Application",
        "ManagedApplication",
        "Module",
        "PolicyDefinition",
        "Prereq",
        "SubscriptionDeployment",
        "ManagementGroupDeployment",
        "TenantDeployment"
      ]
    },
    "icon": {
      "type": "string",
      "enum": [
        "api",
        "blankTemplate",
        "cdnStorage",
        "cdnWebsite",
        "docker",
        "documentDB",
        "logic",
        "serviceFabric",
        "ubuntu",
        "vmss",
        "windowsVM"
      ]
    },
    "tags": {
      "type": "object",
      "additionalProperties": true,
      "description": "Collection of tags or keywords for the sample"
    },
    "environments": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "AzureUSGovernment",
          "AzureCloud",
          "AzureGermanCloud",
          "AzureChinaCloud"
        ]
      },
      "additionalItems": false,
      "additionalProperties": false
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "json",
          "bicep",
          "terraform"
        ]
      },
      "additionalItems": false,
      "additionalProperties": false
    },
    "testResult": {
      "type": "object",
      "description": "Deployment test results. Contains a 'deployments' field with one entry per deployed template.",
      "properties": {
        "deployments": {
          "description": "Array of deployment entries. Each entry requires only templateFileName, correlationId, and deploymentName. TIMESTAMP and templateHash are optional (templateHash is computed from the template file).",
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "templateFileName": {
                    "type": "string",
                    "description": "The template file name (e.g. 'azuredeploy.json', 'main.bicep', 'prereqs/prereq.main.bicep')."
                  },
                  "correlationId": {
                    "type": "string",
                    "description": "The Azure deployment correlation ID."
                  },
                  "deploymentName": {
                    "type": "string",
                    "description": "The Azure deployment name."
                  },
                  "TIMESTAMP": {
                    "type": "string",
                    "description": "Optional. Deployment timestamp (informational only)."
                  },
                  "templateHash": {
                    "type": "string",
                    "description": "Optional. Template hash (ignored — computed from the template file by the validation workflow)."
                  }
                },
                "required": [
                  "templateFileName",
                  "correlationId",
                  "deploymentName"
                ],
                "additionalProperties": true
              }
            },
            {
              "type": "object",
              "description": "Legacy single-object format (non-prereqs samples).",
              "properties": {
                "templateFileName": {
                  "type": "string"
                },
                "correlationId": {
                  "type": "string"
                },
                "deploymentName": {
                  "type": "string"
                },
                "TIMESTAMP": {
                  "type": "string"
                },
                "templateHash": {
                  "type": "string"
                }
              },
              "required": [
                "templateFileName",
                "correlationId",
                "deploymentName"
              ],
              "additionalProperties": true
            }
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "required": [
    "$schema",
    "itemDisplayName",
    "description",
    "summary",
    "githubUsername",
    "dateUpdated",
    "type"
  ],
  "additionalProperties": false
}
